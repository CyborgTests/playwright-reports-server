# Server Configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# Authentication Configuration
#
# API_TOKEN is the master switch for the auth system:
#   - UNSET  → open mode: no login, all endpoints public (unchanged legacy behavior).
#   - SET    → enabled mode: stateful cookie sessions, users, roles, scoped API keys.
#             The value is ALSO the one-time bootstrap secret for first-admin setup
#             (entered in the UI) and seeds a deprecated upload+cli service key so
#             existing reporters/CLIs keep working. Rotate that seed key after setup.
API_TOKEN='my-api-token'

# Idle session lifetime in hours (sliding; bounded by a 30-day absolute cap).
UI_AUTH_EXPIRE_HOURS='12'

# Set the Secure flag on auth cookies. Default true. Set false ONLY for a
# LAN/HTTP (non-TLS) deployment, otherwise the browser drops the session cookie.
COOKIE_SECURE=true

# Break-glass admin (recovery only). When BOTH are set, this account can sign in
# even if every normal admin is disabled/locked out. Unset them after recovery.
ROOT_USERNAME=
ROOT_PASSWORD=

# Storage Configuration
DATA_STORAGE=fs # could be s3 or azure
DATA_DIR=./data

# Frontend Configuration (production only, optional)
# Leave unset for local `pnpm start` - it defaults to ../../apps/frontend/dist.
# Docker sets this automatically (see Dockerfile). Only set it for a custom layout.
# FRONTEND_DIST=/absolute/path/to/apps/frontend/dist

# S3 Configuration (if DATA_STORAGE is "s3")
S3_ENDPOINT="s3.endpoint"
S3_ACCESS_KEY="some_access_key"
S3_SECRET_KEY="some_secret_key"
S3_PORT=9000 # optional
S3_REGION="us-east-1"
S3_USE_SSL=true # default; set to false for local MinIO over plain HTTP
S3_BUCKET="playwright-reports-server" # default
S3_BATCH_SIZE=10 # default
S3_MULTIPART_CHUNK_SIZE_MB=25 # default

# Azure Blob Storage configuration (if DATA_STORAGE is "azure")
# Note: Litestream SQLite replication is only available with DATA_STORAGE=s3.
AZURE_ACCOUNT_NAME="your_storage_account_name"
AZURE_ACCOUNT_KEY="your_storage_account_key"
AZURE_CONTAINER="playwright-reports-server" # default
AZURE_BATCH_SIZE=10 # default