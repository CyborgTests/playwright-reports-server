{
  "name": "pwrs-cli",
  "version": "1.0.0",
  "description": "CLI exposing Playwright Reports Server data to coding agents (Claude Code, Codex, Copilot).",
  "type": "module",
  "bin": {
    "pwrs-cli": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "dev": "tsc --watch",
    "lint": "biome check src",
    "lint:fix": "biome check src --write",
    "format": "biome format src --write",
    "format:check": "biome format src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist/**",
    "README.md",
    "package.json"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "author": "Oleksandr Shevtsov <ovr.shevtsov@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CyborgTests/playwright-reports-server.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/CyborgTests/playwright-reports-server/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/CyborgTests/playwright-reports-server/issues"
  },
  "keywords": [
    "playwright",
    "playwright-reports-server",
    "cli",
    "agent",
    "claude-code",
    "codex",
    "test-failure-analysis"
  ],
  "devDependencies": {
    "@types/node": "^22.19.17",
    "typescript": "5.9.3"
  }
}
