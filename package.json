{
  "name": "playwright-reports-server",
  "version": "6.3.0",
  "description": "Playwright Reports Server: Can be used to accept blobs, merge them, store and view Playwright reports",
  "type": "module",
  "scripts": {
    "dev": "node scripts/build-shared-if-changed.mjs && concurrently --kill-others-on-fail --restart-tries=1 \"pnpm dev:shared\" \"pnpm --filter @playwright-reports/backend dev\" \"pnpm --filter @playwright-reports/frontend dev\"",
    "dev:backend": "node scripts/build-shared-if-changed.mjs && pnpm --filter @playwright-reports/backend dev",
    "dev:frontend": "node scripts/build-shared-if-changed.mjs && pnpm --filter @playwright-reports/frontend dev",
    "dev:shared": "pnpm --filter @playwright-reports/shared dev",
    "build": "pnpm -r --filter './packages/**' --filter './apps/**' run build",
    "build:backend": "pnpm --filter @playwright-reports/backend build",
    "build:frontend": "pnpm --filter @playwright-reports/frontend build",
    "build:shared": "pnpm --filter @playwright-reports/shared build",
    "build:reporter": "pnpm --filter @shelex/playwright-reporter build",
    "build:cli": "pnpm --filter pwrs-cli build",
    "start": "node scripts/build-shared-if-changed.mjs && pnpm --filter @playwright-reports/backend start",
    "test": "pnpm -r --filter './packages/**' --filter './apps/**' run test",
    "test:backend": "pnpm --filter @playwright-reports/backend test",
    "test:frontend": "pnpm --filter @playwright-reports/frontend test",
    "test:reporter": "pnpm --filter @shelex/playwright-reporter test",
    "test:e2e": "playwright test",
    "lint": "pnpm -r --filter './packages/**' --filter './apps/**' run lint",
    "lint:fix": "pnpm -r --filter './packages/**' --filter './apps/**' run lint:fix",
    "lint:reporter": "pnpm --filter @shelex/playwright-reporter lint",
    "lint:cli": "pnpm --filter pwrs-cli lint",
    "format": "pnpm -r --filter './packages/**' --filter './apps/**' run format",
    "format:check": "pnpm -r --filter './packages/**' --filter './apps/**' run format:check",
    "format:reporter": "pnpm --filter @shelex/playwright-reporter format:check",
    "typecheck": "pnpm -r --filter './packages/**' --filter './apps/**' run typecheck",
    "clean": "pnpm -r --filter './packages/**' --filter './apps/**' run clean && rm -rf node_modules",
    "clean:modules": "rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "install:all": "pnpm install",
    "install:backend": "pnpm --filter @playwright-reports/backend install",
    "install:frontend": "pnpm --filter @playwright-reports/frontend install",
    "install:shared": "pnpm --filter @playwright-reports/shared install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@shelex/playwright-reporter": "workspace:*",
    "@playwright/test": "^1.46.0",
    "@types/node": "^22.19.17",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
