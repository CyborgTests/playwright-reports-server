{
	"name": "@playwright-reports/backend",
	"version": "6.0.0",
	"description": "Playwright Reports Server Backend",
	"type": "module",
	"files": ["dist", "public", "package.json"],
	"scripts": {
		"dev": "NODE_ENV=development tsx watch --clear-screen=false src/index.ts",
		"build": "tsc && cp src/lib/utils/llmButton.js dist/lib/utils/llmButton.js",
		"bundle": "node scripts/bundle.mjs",
		"start": "node dist/index.js",
		"typecheck": "tsc --noEmit",
		"test": "echo 'No tests configured for backend'",
		"lint": "biome check src/",
		"lint:fix": "biome check src/ --write",
		"format": "biome format src/ --write",
		"format:check": "biome format src/",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1041.0",
		"@aws-sdk/lib-storage": "^3.1041.0",
		"@aws-sdk/s3-request-presigner": "^3.1041.0",
		"@azure/storage-blob": "^12.28.0",
		"@fastify/cookie": "^11.0.2",
		"@fastify/cors": "^11.2.0",
		"@fastify/jwt": "^10.0.0",
		"@fastify/multipart": "^10.0.0",
		"@fastify/static": "^9.1.3",
		"@playwright-reports/shared": "workspace:*",
		"@playwright/test": "^1.46.0",
		"better-sqlite3": "^12.9.0",
		"croner": "^10.0.1",
		"dotenv": "^17.4.2",
		"envalid": "^8.1.1",
		"fastify": "^5.8.5",
		"get-folder-size": "5.0.0",
		"jsonwebtoken": "^9.0.3",
		"mime": "^4.1.0",
		"unzipper": "^0.12.3",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.13",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^22.19.17",
		"@types/unzipper": "^0.10.11",
		"esbuild": "^0.24.0",
		"pino-pretty": "^13.1.3",
		"tsx": "^4.21.0",
		"typescript": "5.9.3"
	},
	"engines": {
		"node": ">=22.0.0"
	}
}